{
  "info": {
    "name": "Room Management API",
    "description": "Full flow: Register → Login → Room → Tenant → Contract → Meter Reading → Invoice → Payment → Reports",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "landlord_token", "value": "" },
    { "key": "tenant_token", "value": "" },
    { "key": "landlord_id", "value": "" },
    { "key": "tenant_id", "value": "" },
    { "key": "room_id", "value": "" },
    { "key": "contract_id", "value": "" },
    { "key": "meter_reading_id", "value": "" },
    { "key": "invoice_id", "value": "" },
    { "key": "payment_id", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "1.1 Register Landlord",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"landlord01\",\n  \"password\": \"Password@123\",\n  \"email\": \"landlord01@example.com\",\n  \"fullName\": \"Nguyen Van A\",\n  \"phone\": \"0901234567\",\n  \"role\": \"ROLE_LANDLORD\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.success) {",
                "  pm.collectionVariables.set('landlord_token', res.data.accessToken);",
                "  pm.collectionVariables.set('landlord_id', res.data.userId);",
                "  pm.test('Register landlord OK', () => pm.response.to.have.status(201));",
                "}"
              ]
            }
          }]
        },
        {
          "name": "1.2 Login Landlord",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"landlord01\",\n  \"password\": \"Password@123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.success) {",
                "  pm.collectionVariables.set('landlord_token', res.data.accessToken);",
                "  pm.collectionVariables.set('landlord_id', res.data.userId);",
                "  pm.test('Login landlord OK', () => pm.response.to.have.status(200));",
                "}"
              ]
            }
          }]
        },
        {
          "name": "1.3 Get Me (Landlord)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{landlord_token}}" }],
            "url": { "raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api","auth","me"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["pm.test('Get me OK', () => pm.response.to.have.status(200));"]
            }
          }]
        }
      ]
    },
    {
      "name": "2. Room",
