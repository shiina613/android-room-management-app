    {
      "name": "8. Reports",
      "item": [
        {
          "name": "8.1 Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{landlord_token}}" }],
            "url": { "raw": "{{base_url}}/api/reports/dashboard", "host": ["{{base_url}}"], "path": ["api","reports","dashboard"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Dashboard OK', () => pm.response.to.have.status(200));",
