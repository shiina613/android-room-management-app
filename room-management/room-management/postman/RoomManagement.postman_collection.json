        {
          "name": "2.3 Get Room By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{landlord_token}}" }],
            "url": { "raw": "{{base_url}}/api/rooms/{{room_id}}", "host": ["{{base_url}}"], "path": ["api","rooms","{{room_id}}"] }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Get room OK', () => pm.response.to.have.status(200));"] }
          }]
        }
      ]
