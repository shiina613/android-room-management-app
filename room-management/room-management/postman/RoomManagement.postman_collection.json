            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Phòng 101 - Quận 1\",\n  \"address\": \"101 Nguyen Trai, Q1, TP.HCM\",\n  \"price\": 3500000,\n  \"elecPrice\": 3500,\n  \"waterPrice\": 15000,\n  \"servicePrice\": 200000,\n  \"category\": \"STUDIO\",\n  \"status\": \"AVAILABLE\",\n  \"description\": \"Phòng studio đầy đủ nội thất\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.success) {",
                "  pm.collectionVariables.set('room_id', res.data.id);",
                "  pm.test('Create room OK', () => pm.response.to.have.status(201));",
                "}"
              ]
            }
          }]
        },
        {
          "name": "2.2 List Rooms",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{landlord_token}}" }],
            "url": {
              "raw": "{{base_url}}/api/rooms?status=AVAILABLE&page=0&size=10",
              "host": ["{{base_url}}"], "path": ["api","rooms"],
              "query": [
                { "key": "status", "value": "AVAILABLE" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('List rooms OK', () => pm.response.to.have.status(200));"] }
          }]
